# CompliGate Backend Config
POLICY_VERSION=RLUSD_US_v1
JURISDICTION=US
CURRENCY=RLUSD

# Set issuer later once you confirm RLUSD issuer on testnet
ISSUER_ADDRESS=rEXAMPLE_ISSUER_ADDRESS

# Optional for MVP:
# If blank, backend generates an ephemeral Ed25519 key on each run.
# If set, should be base64 of a 32-byte Ed25519 seed.
COMPLIGATE_PRIVATE_KEY_B64=

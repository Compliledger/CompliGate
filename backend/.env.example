# CompliGate Backend Configuration

# Policy settings
POLICY_VERSION=RLUSD_US_v1
JURISDICTION=US
CURRENCY=RLUSD

# Issuer address on XRPL (update for mainnet)
ISSUER_ADDRESS=rEXAMPLE_ISSUER_ADDRESS

# Optional: Base64-encoded Ed25519 seed (32 bytes).
# If blank, an ephemeral key is generated on each run (MVP mode).
COMPLIGATE_PRIVATE_KEY_B64=

# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Set to true to enable XRPL transaction endpoints
FEATURE_XRPL=false
